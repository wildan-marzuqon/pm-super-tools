datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Note {
  id        String       @id @default(uuid())
  title     String
  content   String       @db.Text
  folder    String       @default("Uncategorized")
  tags      String[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  actions   ActionItem[]

  @@map("notes")
}

model ActionItem {
  id           String   @id @default(uuid())
  title        String
  description  String   @default("") @db.Text
  deadline     String   @default("")
  pic          String   @default("")
  completed    Boolean  @default(false)
  sourceNoteId String?  @map("source_note_id")
  projectId    String?  @map("project_id")
  categoryId   String?  @map("category_id")
  createdAt    DateTime @default(now()) @map("created_at")

  note     Note?            @relation(fields: [sourceNoteId], references: [id], onDelete: SetNull)
  project  Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category ProjectCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("action_items")
}

model Project {
  id                String            @id @default(uuid())
  name              String
  description       String            @default("") @db.Text
  deadline          String            @default("")
  pic               String            @default("")
  currentStageIndex Int               @default(0) @map("current_stage_index")
  createdAt         DateTime          @default(now()) @map("created_at")
  stages            ProjectStage[]
  actions           ActionItem[]
  artifacts         Artifact[]
  categories        ProjectCategory[]

  @@map("projects")
}

model ProjectCategory {
  id        String       @id @default(uuid())
  projectId String       @map("project_id")
  name      String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actions   ActionItem[]

  @@map("project_categories")
}

model ProjectStage {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  name        String
  order       Int
  completedAt DateTime? @map("completed_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_stages")
}

model Artifact {
  id          String @id @default(uuid())
  projectId   String @map("project_id")
  label       String
  url         String
  description String @default("")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("artifacts")
}

model JiraIssue {
  id               String    @id @default(uuid())
  key              String    @unique
  issueType        String    @map("issue_type")
  summary          String
  assignee         String    @default("Unassigned")
  priority         String
  status           String
  startDate        DateTime? @map("start_date")
  dueDate          DateTime? @map("due_date")
  originalEstimate Float     @map("original_estimate") // in seconds
  createdAt        DateTime  @default(now()) @map("created_at")

  @@map("jira_issues")
}
