datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Note {
  id        String       @id @default(uuid())
  title     String
  content   String       @db.Text
  folder    String       @default("Uncategorized")
  tags      String[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  actions   ActionItem[]

  @@map("notes")
}

model ActionItem {
  id           String   @id @default(uuid())
  title        String
  description  String   @default("") @db.Text
  deadline     String   @default("")
  startDate    String   @default("") @map("start_date")
  pic          String   @default("")
  completed    Boolean  @default(false)
  sourceNoteId String?  @map("source_note_id")
  projectId    String?  @map("project_id")
  categoryId   String?  @map("category_id")
  status       String   @default("open")
  originalEstimate Int  @default(0) @map("original_estimate")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  // WhatsApp Copilot specific fields
  sourceType    String    @default("manual") @map("source_type")
  waChatName    String?   @map("wa_chat_name")
  waChatLink    String?   @map("wa_chat_link")
  waExtractedAt DateTime? @map("wa_extracted_at")

  // Jira sync fields
  jiraKey      String?   @map("jira_key")
  jiraSyncedAt DateTime? @map("jira_synced_at")

  note     Note?            @relation(fields: [sourceNoteId], references: [id], onDelete: SetNull)
  project  Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category ProjectCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  dailyPlanEntries DailyPlanEntry[]

  @@map("action_items")
}

model Project {
  id                   String            @id @default(uuid())
  name                 String
  description          String            @default("") @db.Text
  deadline             String            @default("")
  pic                  String            @default("")
  currentStageIndex    Int               @default(0) @map("current_stage_index")
  googleDriveFolderUrl String?           @map("google_drive_folder_url")
  googleApiKey         String?           @map("google_api_key")
  jiraProjectKey       String?           @map("jira_project_key")
  createdAt            DateTime          @default(now()) @map("created_at")
  stages               ProjectStage[]
  actions              ActionItem[]
  artifacts            Artifact[]
  categories           ProjectCategory[]
  decisions            Decision[]
  risks                ProjectRisk[]

  @@map("projects")
}

model ProjectCategory {
  id        String       @id @default(uuid())
  projectId String       @map("project_id")
  name      String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actions   ActionItem[]

  @@map("project_categories")
}

model ProjectStage {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  name        String
  order       Int
  completedAt DateTime? @map("completed_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_stages")
}

model Artifact {
  id          String  @id @default(uuid())
  projectId   String  @map("project_id")
  label       String
  url         String
  description String  @default("")
  isSynced    Boolean @default(false) @map("is_synced")
  type        String  @default("link") // "link", "document"
  content     String?                  // For local rich-text content

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("artifacts")
}

model JiraIssue {
  id               String    @id @default(uuid())
  key              String    @unique
  issueType        String    @map("issue_type")
  summary          String
  assignee         String    @default("Unassigned")
  priority         String
  status           String
  startDate        DateTime? @map("start_date")
  dueDate          DateTime? @map("due_date")
  originalEstimate Float     @map("original_estimate") // in seconds
  createdAt        DateTime  @default(now()) @map("created_at")

  @@map("jira_issues")
}

model SystemSetting {
  id                 String   @id @default("default")
  tgBotName          String?  @map("tg_bot_name")
  tgBotToken         String?  @map("tg_bot_token")
  tgBotPin           String   @default("1234") @map("tg_bot_pin")
  geminiApiKey       String?  @map("gemini_api_key")
  appUrl             String?  @map("app_url")
  jiraUrl            String?  @map("jira_url")
  jiraEmail          String?  @map("jira_email")
  jiraToken          String?  @map("jira_token")
  actionItemStatuses String[] @default(["Pending", "Open", "In Progress", "Selesai"]) @map("action_item_statuses")
  jiraSyncStatuses   String[] @default(["To Do", "In Progress", "Done"]) @map("jira_sync_statuses")
  jiraSyncDaysBack   Int      @default(30) @map("jira_sync_days_back")
  jiraSyncMaxResults Int      @default(500) @map("jira_sync_max_results")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model TelegramSession {
  chatId       String   @id @map("chat_id")
  username     String?
  isAuthorized Boolean  @default(false) @map("is_authorized")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("telegram_sessions")
}

model WAPendingFile {
  id           Int      @id @default(autoincrement())
  chatId       String   @map("chat_id")
  fileName     String   @map("file_name")
  fileContent  String   @db.Text @map("file_content")
  dates        String[]
  selectedDate String?  @map("selected_date")
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("wa_pending_files")
}

model WACopilotDraft {
  id          String   @id @default(uuid())
  type        String
  title       String
  description String   @default("") @db.Text
  pic         String   @default("")
  deadline    String   @default("")
  rawChat     String   @db.Text @map("raw_chat")
  status      String   @default("pending")
  projectId   String?  @map("project_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("wa_copilot_drafts")
}

model Decision {
  id          String   @id @default(uuid())
  summary     String   @db.Text
  decidedBy   String?  @map("decided_by")
  projectId   String?  @map("project_id")
  waChatName  String?  @map("wa_chat_name")
  waChatLink  String?  @map("wa_chat_link")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("decisions")
}

model ProjectRisk {
  id          String    @id @default(uuid())
  issue       String    @db.Text
  impact      String?   @db.Text
  status      String    @default("active") // "active", "resolved"
  severity    String    @default("medium") // "low", "medium", "high"
  projectId   String?   @map("project_id")
  waChatName  String?   @map("wa_chat_name")
  waChatLink  String?   @map("wa_chat_link")
  createdAt   DateTime  @default(now()) @map("created_at")
  resolvedAt  DateTime? @map("resolved_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_risks")
}

model DailyPlanEntry {
  id           String      @id @default(cuid())
  date         String      // "2026-06-24"
  startTime    String?     // "09:00" — nullable for unscheduled entries
  endTime      String?     // "10:00" — nullable for unscheduled entries
  type         String      @default("task")  // "task" | "meeting" | "focus"
  title        String
  notes        String?     @db.Text
  status       String      @default("open")  // task: open/in_progress/done | meeting: pending/done/skipped
  actionItemId String?     @map("action_item_id")
  actionItem   ActionItem? @relation(fields: [actionItemId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())   @map("created_at")
  updatedAt    DateTime    @updatedAt        @map("updated_at")

  @@map("daily_plan_entries")
}
